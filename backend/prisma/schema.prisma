generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================================================================
// Enums
// =========================================================================

enum DocumentStatus {
  PENDING_UPLOAD
  DRAFT
  ACTIVE
  INFECTED
  ARCHIVED
  EXPIRING_SOON
  EXPIRED
}

enum DocumentClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum StorageProvider {
  SUPABASE
  LOCAL
  AWS_S3
}

enum ApprovalStatus {
  DRAFT
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum ApprovalAction {
  CREATED
  SUBMITTED
  APPROVED
  REJECTED
  REASSIGNED
  CANCELLED
}

enum ApprovalReferenceType {
  CHECKOUT
  DOCUMENT
  USER_ACCESS
  EXTERNAL_SHARE
}

enum SignatureType {
  DRAWN
  UPLOADED
  CERTIFICATE
}

enum SignatureStatus {
  CREATED
  PENDING_VERIFICATION
  VERIFIED
  FAILED
  REVOKED
}

enum SignatureReferenceType {
  CHECKOUT
  RETURN
  APPROVAL
  DOCUMENT
}

enum VaultType {
  DEPARTMENT
  PROJECT
  CLIENT
  CUSTOM
}

enum VaultStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum FolderStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum FolderPermissionType {
  READ
  WRITE
  ADMIN
}

enum AuditCategory {
  AUTHENTICATION
  DOCUMENT
  CHECKOUT
  APPROVAL
  SIGNATURE
  USER_MANAGEMENT
  SYSTEM
  SECURITY
}

enum AuditAction {
  CREATE
  VIEW
  UPDATE
  DELETE
  DOWNLOAD
  UPLOAD
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  VERIFY
  EXPORT
}

enum AuditResult {
  SUCCESS
  FAILED
  DENIED
}

// =========================================================================
// Models
// =========================================================================

model User {
  id           String      @id
  email        String      @unique
  role         String      @default("VIEWER")
  departmentId String?     @map("department_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relationships
  department        Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ownedDocuments    Document[]        @relation("DocumentOwner")
  lockedDocuments   Document[]        @relation("DocumentLocker")
  folders           Folder[]
  ownedVaults       Vault[]           @relation("VaultOwner")
  folderPermissions FolderPermission[]
  approvalRequestsCreated  ApprovalRequest[] @relation("ApprovalRequestsCreated")
  approvalRequestsAssigned ApprovalRequest[] @relation("ApprovalRequestsAssigned")
  approvalStepsAssigned    ApprovalStep[]
  auditLogs         AuditLog[]
  sessions          Session[]
  requestedCheckouts Checkout[] @relation("RequestedCheckouts")
  approvedCheckouts  Checkout[] @relation("ApprovedCheckouts")
  signatures         DigitalSignature[] @relation("UserSignatures")
  verifiedSignatures DigitalSignature[] @relation("VerifierSignatures")
  notifications      Notification[]
  notificationPreference NotificationPreference? @relation("UserNotificationPreferences")
  reports           Report[]          @relation("UserReports")
  scheduledReports  ScheduledReport[] @relation("UserScheduledReports")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  device    String?
  browser   String?
  os        String?
  ipAddress String?  @map("ip_address")
  status    String   @default("ACTIVE")
  isTrusted Boolean  @default(false) @map("is_trusted")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  users     User[]
  folders   Folder[]
  documents Document[]
  vaults    Vault[]

  @@map("departments")
}

model Vault {
  id           String      @id @default(uuid())
  name         String      @unique
  description  String?
  type         VaultType   @default(CUSTOM)
  status       VaultStatus @default(ACTIVE)
  ownerId      String      @map("owner_id")
  departmentId String?     @map("department_id")
  isArchived   Boolean     @default(false) @map("is_archived")
  isDeleted    Boolean     @default(false) @map("is_deleted")
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relationships
  owner        User        @relation("VaultOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  folders      Folder[]
  documents    Document[]

  @@map("vaults")
}

model Folder {
  id           String         @id @default(uuid())
  name         String
  parentId     String?        @map("parent_id")
  vaultId      String?        @map("vault_id")
  departmentId String?        @map("department_id")
  ownerId      String         @map("owner_id")
  
  // Folder attributes
  path         String         @default("/") @map("path")
  status       FolderStatus   @default(ACTIVE)
  isArchived   Boolean        @default(false) @map("is_archived")
  isDeleted    Boolean        @default(false) @map("is_deleted")
  deletedAt    DateTime?      @map("deleted_at")
  
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // Relationships
  parent       Folder?        @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  subFolders   Folder[]       @relation("SubFolders")
  vault        Vault?         @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  department   Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents    Document[]
  permissions  FolderPermission[]

  @@map("folders")
}

model FolderPermission {
  id         String               @id @default(uuid())
  folderId   String               @map("folder_id")
  userId     String               @map("user_id")
  permission FolderPermissionType @default(READ)
  createdAt  DateTime             @default(now()) @map("created_at")

  // Relationships
  folder     Folder               @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("folder_permissions")
}

model Document {
  id              String                 @id @default(uuid())
  name            String
  documentNumber  String?                @unique @map("document_number")
  description     String?
  tags            String[]               @default([])
  folderId        String?                @map("folder_id")
  vaultId         String?                @map("vault_id")
  departmentId    String?                @map("department_id")
  ownerId         String                 @map("owner_id")
  
  // Storage information
  storageProvider StorageProvider        @default(SUPABASE) @map("storage_provider")
  storageBucket   String                 @map("storage_bucket")
  storagePath     String                 @map("storage_path")
  
  // File metadata
  mimeType        String                 @map("mime_type")
  fileSize        BigInt                 @map("file_size")
  checksum        String?                @map("checksum")
  
  // Lifecycle & security
  classification  DocumentClassification @default(INTERNAL)
  status          DocumentStatus         @default(PENDING_UPLOAD)
  expiryDate      DateTime?              @map("expiry_date")
  version         Int                    @default(1)
  isLocked        Boolean                @default(false) @map("is_locked")
  lockedById      String?                @map("locked_by_id")
  lockedAt        DateTime?              @map("locked_at")
  
  // Soft delete & Archiving
  isDeleted       Boolean                @default(false) @map("is_deleted")
  deletedAt       DateTime?              @map("deleted_at")
  
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  // Relationships
  owner            User                   @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  lockedBy         User?                  @relation("DocumentLocker", fields: [lockedById], references: [id], onDelete: SetNull)
  folder           Folder?                @relation(fields: [folderId], references: [id], onDelete: SetNull)
  vault            Vault?                 @relation(fields: [vaultId], references: [id], onDelete: SetNull)
  department       Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  versions         FileVersion[]
  checkouts        Checkout[]

  @@map("documents")
}

model FileVersion {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  version    Int
  filePath   String   @map("file_path")
  changeLog  String   @map("change_log")
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relationships
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("file_versions")
}

model ApprovalRequest {
  id                  String                @id @default(uuid())
  referenceType       ApprovalReferenceType @map("reference_type")
  referenceId         String                @map("reference_id")
  title               String
  description         String?
  reason              String?

  // Requester snapshot fields
  requesterId         String                @map("requester_id")
  requestedAt         DateTime              @default(now()) @map("requested_at")
  requesterName       String?               @map("requester_name")
  requesterDepartment  String?               @map("requester_department")
  requesterDesignation String?               @map("requester_designation")

  // Workflow parameters
  currentStep         Int                   @default(1) @map("current_step")
  totalSteps          Int                   @default(1) @map("total_steps")
  currentApproverId   String?               @map("current_approver_id")
  approvalLevel       String?               @map("approval_level")
  priority            String                @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  status              ApprovalStatus        @default(DRAFT)

  // Soft delete
  isDeleted           Boolean               @default(false) @map("is_deleted")
  deletedAt           DateTime?             @map("deleted_at")
  deletedBy           String?               @map("deleted_by")

  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  // Relations
  requester           User                  @relation("ApprovalRequestsCreated", fields: [requesterId], references: [id], onDelete: Cascade)
  currentApprover     User?                 @relation("ApprovalRequestsAssigned", fields: [currentApproverId], references: [id], onDelete: SetNull)
  steps               ApprovalStep[]
  history             ApprovalHistory[]

  @@index([referenceType])
  @@index([referenceId])
  @@index([status])
  @@index([requesterId])
  @@index([currentApproverId])
  @@index([createdAt])
  @@index([priority])
  @@map("approval_requests")
}

model ApprovalStep {
  id                String         @id @default(uuid())
  approvalRequestId String         @map("approval_request_id")
  stepNumber        Int            @map("step_number")
  approverId        String         @map("approver_id")
  approverRole      String?        @map("approver_role")
  status            ApprovalStatus @default(PENDING)
  decisionDate      DateTime?      @map("decision_date")
  comments          String?
  actionTaken       String?        @map("action_taken")
  approverName      String?        @map("approver_name")

  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approver          User           @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
  @@index([approverId])
  @@map("approval_steps")
}

model ApprovalHistory {
  id                String         @id @default(uuid())
  approvalRequestId String         @map("approval_request_id")
  action            ApprovalAction
  performedBy       String         @map("performed_by")
  timestamp         DateTime       @default(now())
  previousState     ApprovalStatus @map("previous_state")
  newState          ApprovalStatus @map("new_state")
  remarks           String?

  createdAt         DateTime       @default(now()) @map("created_at")

  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
  @@map("approval_histories")
}

model AuditLog {
  id                 String        @id @default(uuid())
  eventRef           String        @unique @map("event_ref")
  
  // Identity snapshot
  userId             String?       @map("user_id")
  userSnapshot       Json?         @map("user_snapshot")
  roleSnapshot       String?       @map("role_snapshot")
  departmentSnapshot String?       @map("department_snapshot")

  // Event information
  eventType          String        @map("event_type")
  category           AuditCategory
  action             AuditAction
  description        String?

  // Resource binding
  referenceType      String?       @map("reference_type")
  referenceId        String?       @map("reference_id")

  // Change tracking
  previousState      Json?         @map("previous_state")
  newState           Json?         @map("new_state")

  // Request context
  ipAddress          String?       @map("ip_address")
  userAgent          String?       @map("user_agent")
  device             String?
  browser            String?
  os                 String?
  sessionId          String?       @map("session_id")

  // Security context
  authMethod         String?       @map("auth_method")
  mfaStatus          String?       @map("mfa_status")
  permissionUsed     String?       @map("permission_used")
  result             AuditResult

  // Metadata
  metadata           Json?

  // Integrity protection
  recordHash         String?       @map("record_hash")
  prevRecordHash     String?       @map("prev_record_hash")
  sequenceNumber     Int           @default(autoincrement()) @map("sequence_number")

  // Retention support
  retentionPeriod    Int?          @map("retention_period")
  archiveStatus      String?       @default("ACTIVE") @map("archive_status")
  archivedAt         DateTime?     @map("archived_at")

  createdAt          DateTime      @default(now()) @map("created_at")

  // Relationships
  user               User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([category])
  @@index([action])
  @@index([createdAt])
  @@index([referenceType])
  @@index([referenceId])
  @@index([result])
  @@map("audit_logs")
}

enum CheckoutStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHECKED_OUT
  PENDING_RETURN
  RETURNED
  CLOSED
  CANCELLED
}

enum ReturnCondition {
  GOOD
  DAMAGED
  MISSING
  NEEDS_REVIEW
}

model Checkout {
  id                    String                 @id @default(uuid())
  documentId            String                 @map("document_id")
  documentVersionId     String?                @map("document_version_id")
  documentNameSnapshot  String                 @map("document_name_snapshot")
  classificationSnapshot DocumentClassification @map("classification_snapshot")

  requestedById         String                 @map("requested_by_id")
  employeeId            String?                @map("employee_id")
  employeeName          String                 @map("employee_name")
  department            String                 // Snapshot department name
  designation           String?

  checkoutDate          DateTime               @default(now()) @map("checkout_date")
  destination           String
  locationAddress       String                 @map("location_address")
  externalOrganizationName String?            @map("external_organization_name")
  purposeOfRemoval      String                 @map("purpose_of_removal")
  expectedReturnDate    DateTime?              @map("expected_return_date")

  status                CheckoutStatus         @default(DRAFT)
  approvedById          String?                @map("approved_by_id")
  approvedAt            DateTime?              @map("approved_at")
  rejectionReason       String?                @map("rejection_reason")

  approvalId            String?                @map("approval_id")
  approvalComments      String?                @map("approval_comments")
  approvalStatus        String?                @map("approval_status")
  currentLocation       String?                @map("current_location")

  returnStatus          String?                @map("return_status")
  returnedDate          DateTime?              @map("returned_date")
  returnedTo            String?                @map("returned_to")
  conditionOnReturn     ReturnCondition?       @map("condition_on_return")
  returnNotes           String?                @map("return_notes")

  checkoutSignatureId   String?                @map("checkout_signature_id")
  returnSignatureId     String?                @map("return_signature_id")

  isDeleted             Boolean                @default(false) @map("is_deleted")
  deletedAt             DateTime?              @map("deleted_at")
  deletedById           String?                @map("deleted_by_id")

  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  // Relationships
  document              Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  requestedBy           User                   @relation("RequestedCheckouts", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy            User?                  @relation("ApprovedCheckouts", fields: [approvedById], references: [id], onDelete: SetNull)
  movements             CheckoutMovement[]

  @@index([documentId])
  @@index([requestedById])
  @@index([status])
  @@index([checkoutDate])
  @@index([expectedReturnDate])
  @@index([department])
  @@map("checkouts")
}

enum MovementStatus {
  CREATED
  APPROVED_FOR_RELEASE
  CHECKED_OUT
  LEFT_OFFICE
  IN_TRANSIT
  DELIVERED
  WITH_EXTERNAL_PARTY
  RETURN_INITIATED
  RETURN_IN_TRANSIT
  RETURN_RECEIVED
  COMPLETED
}

model CheckoutMovement {
  id                 String         @id @default(uuid())
  checkoutId         String         @map("checkout_id")
  documentId         String         @map("document_id")
  versionId          String?        @map("version_id")

  // Movement details
  currentLocation    String         @map("current_location")
  previousLocation   String?        @map("previous_location")
  destinationAddress String?        @map("destination_address")
  externalOrganization String?      @map("external_organization")
  status             MovementStatus @default(CREATED)
  movementDate       DateTime       @map("movement_date")
  movementTime       String?        @map("movement_time")
  remarks            String?

  // Handler / Responsible Person
  handlerName        String         @map("handler_name")
  employeeId         String?        @map("employee_id")
  contactReference   String?        @map("contact_reference")
  department         String?        @map("department")

  // QR scan prep fields
  trackingReference  String?        @map("tracking_reference")
  qrIdentifier       String?        @map("qr_identifier")
  scanTimestamp      DateTime?      @map("scan_timestamp")
  scanLocation       String?        @map("scan_location")

  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  checkout           Checkout       @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@index([checkoutId])
  @@map("checkout_movements")
}

model DigitalSignature {
  id                  String                 @id @default(uuid())
  signatureRefNumber  String                 @unique @map("signature_ref_number")
  signatureType       SignatureType          @map("signature_type")
  status              SignatureStatus        @default(CREATED)

  // Owner snapshots
  userId              String                 @map("user_id")
  userSnapshot        String?                @map("user_snapshot")
  departmentSnapshot  String?                @map("department_snapshot")

  // Reference binding
  referenceType       SignatureReferenceType @map("reference_type")
  referenceId         String                 @map("reference_id")

  // Storage details
  storageProvider     String                 @default("SUPABASE") @map("storage_provider")
  bucketName          String                 @map("bucket_name")
  storagePath         String                 @map("storage_path")
  fileHash            String?                @map("file_hash")
  signatureHash       String                 @map("signature_hash")

  // Signature data
  originalFilename    String?                @map("original_filename")
  mimeType            String?                @map("mime_type")
  fileSize            BigInt?                @map("file_size")
  checksum            String?
  encodingMetadata    String?                @map("encoding_metadata")

  // Verification data
  verificationStatus  String?                @map("verification_status")
  verificationHash    String?                @map("verification_hash")
  verifiedBy          String?                @map("verified_by")
  verifiedAt          DateTime?              @map("verified_at")
  verificationMethod  String?                @map("verification_method")
  verificationAttempts Int                 @default(0) @map("verification_attempts")
  lastVerificationAttemptAt DateTime?        @map("last_verification_attempt_at")

  // Transaction binding
  transactionId       String?                @map("transaction_id")
  transactionType     String?                @map("transaction_type")
  transactionSnapshot Json?                  @map("transaction_snapshot")
  bindingHash         String?                @map("binding_hash")
  boundAt             DateTime?              @map("bound_at")
  boundBy             String?                @map("bound_by")
  bindingStatus       String?                @map("binding_status")

  // Soft delete
  isDeleted           Boolean                @default(false) @map("is_deleted")
  deletedAt           DateTime?              @map("deleted_at")
  deletedBy           String?                @map("deleted_by")

  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  // Relations
  user                User                   @relation("UserSignatures", fields: [userId], references: [id], onDelete: Cascade)
  verifier            User?                  @relation("VerifierSignatures", fields: [verifiedBy], references: [id], onDelete: SetNull)
  history             SignatureHistory[]

  @@index([userId])
  @@index([referenceType])
  @@index([referenceId])
  @@index([status])
  @@index([createdAt])
  @@index([verificationStatus])
  @@map("digital_signatures")
}

model SignatureHistory {
  id                 String           @id @default(uuid())
  signatureId        String           @map("signature_id")
  action             String           // CREATED, UPLOADED, VERIFIED, FAILED, REVOKED
  performedBy        String           @map("performed_by")
  timestamp          DateTime         @default(now())
  metadata           Json?

  createdAt          DateTime         @default(now()) @map("created_at")

  signature          DigitalSignature @relation(fields: [signatureId], references: [id], onDelete: Cascade)

  @@index([signatureId])
  @@map("signature_histories")
}

enum NotificationCategory {
  DOCUMENT
  CHECKOUT
  APPROVAL
  SIGNATURE
  SECURITY
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  REAL_TIME
}

enum NotificationStatus {
  PENDING
  DELIVERED
  READ
  FAILED
  ARCHIVED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model Notification {
  id                 String               @id @default(uuid())
  refNumber          String               @unique @map("ref_number")
  userId             String               @map("user_id")
  userSnapshot       Json?                @map("user_snapshot")
  departmentSnapshot String?              @map("department_snapshot")
  title              String
  message            String
  description        String?
  category           NotificationCategory
  priority           NotificationPriority @default(NORMAL)
  referenceType      String?              @map("reference_type")
  referenceId        String?              @map("reference_id")
  status             NotificationStatus   @default(PENDING)
  expiryDate         DateTime?            @map("expiry_date")
  archivedAt         DateTime?            @map("archived_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  // Relationships
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries         NotificationDelivery[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([priority])
  @@index([referenceType, referenceId])
  @@map("notifications")
}

model NotificationDelivery {
  id                 String              @id @default(uuid())
  notificationId     String              @map("notification_id")
  channel            NotificationChannel
  status             NotificationStatus  @default(PENDING)
  attemptCount       Int                 @default(0) @map("attempt_count")
  deliveredAt        DateTime?           @map("delivered_at")
  failedReason       String?             @map("failed_reason")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  // Relationships
  notification       Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  emailEnabled       Boolean   @default(true) @map("email_enabled")
  inAppEnabled       Boolean   @default(true) @map("in_app_enabled")
  realTimeEnabled    Boolean   @default(true) @map("real_time_enabled")
  categoryPreferences Json?     @map("category_preferences")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relationships
  user               User      @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

enum ReportType {
  DOCUMENT_ACTIVITY
  CHECKOUT_REPORT
  RETURN_REPORT
  APPROVAL_REPORT
  SIGNATURE_REPORT
  AUDIT_REPORT
  USER_ACTIVITY
  SECURITY_REPORT
  COMPLIANCE_REPORT
  SYSTEM_REPORT
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
}

enum ReportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  ARCHIVED
}

model Report {
  id                 String        @id @default(uuid())
  refNumber          String        @unique @map("ref_number")
  name               String
  type               ReportType
  description        String?
  format             ReportFormat
  status             ReportStatus  @default(QUEUED)
  userId             String?       @map("user_id")
  userSnapshot       Json?         @map("user_snapshot")
  departmentSnapshot String?       @map("department_snapshot")
  filters            Json?
  sorting            Json?
  columns            Json?
  storageProvider    String?       @map("storage_provider")
  bucketName         String?       @map("bucket_name")
  filePath           String?       @map("file_path")
  fileName           String?       @map("file_name")
  fileSize           BigInt?       @map("file_size")
  fileHash           String?       @map("file_hash")
  generatedAt        DateTime?     @map("generated_at")
  expiryDate         DateTime?     @map("expiry_date")
  startedAt          DateTime?     @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  processingTime     Int?          @map("processing_time")
  failureReason      String?       @map("failure_reason")
  retryCount         Int           @default(0) @map("retry_count")
  autoArchive        Boolean       @default(false) @map("auto_archive")
  retentionPeriod    Int?          @map("retention_period")
  scheduledReportId  String?       @map("scheduled_report_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user               User?            @relation("UserReports", fields: [userId], references: [id], onDelete: SetNull)
  scheduledReport    ScheduledReport? @relation(fields: [scheduledReportId], references: [id], onDelete: SetNull)
  history            ReportHistory[]

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([departmentSnapshot])
  @@index([createdAt])
  @@index([generatedAt])
  @@map("reports")
}

model ReportHistory {
  id          String   @id @default(uuid())
  reportId    String   @map("report_id")
  action      String
  performedBy String   @map("performed_by")
  timestamp   DateTime @default(now())
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([action])
  @@index([createdAt])
  @@map("report_histories")
}

model ScheduledReport {
  id                String       @id @default(uuid())
  name              String
  reportType        ReportType   @map("report_type")
  format            ReportFormat
  frequency         String
  recipients        String[]     @default([])
  filters           Json?
  sorting           Json?
  columns           Json?
  nextExecutionTime DateTime?    @map("next_execution_time")
  isActive          Boolean      @default(true) @map("is_active")
  ownerId           String       @map("owner_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  owner             User         @relation("UserScheduledReports", fields: [ownerId], references: [id], onDelete: Cascade)
  reports           Report[]

  @@map("scheduled_reports")
}